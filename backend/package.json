    "build": "tsup src/index.ts --format cjs --out-dir dist --no-splitting",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "express": "^4.19.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "ts-node-dev": "^2.0.0",
    "tsup": "^8.0.0"
  }
}
